# ============================================================
# STRIDE Vision Agent — Configuração de ambiente
# Copie este arquivo para ".env" e preencha os valores.
# NUNCA faça commit do arquivo .env real (já está no .gitignore).
# ============================================================

# --- Geral ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# Origens do frontend com permissão de CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# --- Provedor de IA ativo: gemini | groq | azure_openai | ollama ---
AI_PROVIDER=gemini

# --- Google Gemini (padrão, gratuito) ---
# Crie sua chave gratuita em: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Groq (alternativa gratuita e muito rápida) ---
# Crie sua chave gratuita em: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.2-11b-vision-preview

# --- Azure OpenAI (apenas se você tiver assinatura paga/ativa) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=

# --- Ollama (100% local, sem chave) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision

# --- Limites ---
MAX_IMAGE_SIZE_MB=8
ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/webp
RATE_LIMIT_PER_MINUTE=10
