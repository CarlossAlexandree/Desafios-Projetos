# Idioma padrão para reconhecimento de voz e síntese de fala
ASSISTANT_LANGUAGE=pt-BR
TTS_LANGUAGE=pt

# Nome de ativação do assistente (usado nos logs/respostas)
ASSISTANT_NAME=Jarvis

# Diretório para salvar arquivos de áudio temporários
AUDIO_OUTPUT_DIR=./audio_output

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_DIR=./logs

# Tempo (segundos) de calibração de ruído ambiente do microfone
AMBIENT_NOISE_DURATION=1

# Raio de busca (metros) para localizar a farmácia mais próxima
PHARMACY_SEARCH_RADIUS_M=3000
