# =========================================================
# Configuração de provedor de LLM
# Valores possíveis: "azure" ou "gemini"
# O sistema tenta "azure" primeiro e cai para "gemini"
# automaticamente se detectar erro de cota/autenticação.
# =========================================================
LLM_PROVIDER=azure

# --- Azure OpenAI (créditos gratuitos de trial) ---
AZURE_OPENAI_API_KEY=coloque_sua_chave_aqui
AZURE_OPENAI_ENDPOINT=https://SEU-RECURSO.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# --- Google Gemini (fallback 100% gratuito) ---
# Gere sua chave em https://aistudio.google.com/apikey
GOOGLE_API_KEY=coloque_sua_chave_aqui
GEMINI_MODEL=gemini-1.5-flash

# --- Parâmetros do gerador ---
MAX_TDD_ITERATIONS=3
LOG_LEVEL=INFO
